# Pterodactyl Panel - Environment Configuration
# Copia este archivo como .env: cp .env.example .env
# O simplemente ejecuta: docker compose up -d (el entrypoint lo genera automáticamente)

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_THEME=pterodactyl
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_ENVIRONMENT_ONLY=false

# Database
DB_HOST=database
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=pterodactyl_secret_pw

# Redis / Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=cache
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (deshabilitado por defecto - configura si necesitas notificaciones)
MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME="Pterodactyl Panel"

# Hashids
HASHIDS_SALT=
HASHIDS_LENGTH=8
